# ArxivPulse 环境配置示例
# 复制此文件为 .env 并填入实际值

# 服务器配置
PORT=3000
NODE_ENV=production

# 数据库配置
DATABASE_PATH=./data/arxiv-pulse.db

# 域名配置
BASE_URL=https://www.reset-group.site/arxiv-papers

# GitHub 配置（可选，用于自动同步）
# GITHUB_TOKEN=your_github_token_here
# GITHUB_REPO=yangzhangs/arxiv-pulse

# 飞书配置（可选，用于发送通知）
# FEISHU_BOT_URL=your_feishu_bot_webhook_url
